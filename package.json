{
  "name": "mcp-frete-tributario",
  "version": "1.0.0",
  "description": "Servidor MCP para cálculo e consulta de tributação de frete — Reforma Tributária brasileira (LC 214/2025)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('data',{recursive:true});fs.copyFileSync('src/data/cronograma-reforma.json','data/cronograma-reforma.json');fs.copyFileSync('src/data/empresas.json','data/empresas.json');console.log('data files copied')\"",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "fast-check": "^3.22.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
